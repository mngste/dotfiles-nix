sort=-time
layer=overlay
markup=1
actions=1
default-timeout=10000
ignore-timeout=1

# Format
font=JetBrainsMono Nerd Font Propo 10
border-size=1
border-radius=5
border-color=#D9EAE2
background-color=#000000
text-color=#A9DC76

# icons
icons=1
max-icon-size=36
icon-location=left
icon-border-radius=4

[mode=dnd]
invisible=1

[urgency=low]
border-color=#D9EAE2

[urgency=normal]
border-color=#D9EAE2

[urgency=high]
border-color=#CA3448
default-timeout=30000
